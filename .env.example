# =============================================================================
# Summarize_p2 API Server — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Server ---
# Auth is configured via accounts in config.json, not env vars.
# See docs/api-server.md for details.
SUMMARIZE_API_PORT=3000            # Optional. Default: 3000
# SUMMARIZE_DATA_DIR=              # Optional. Root directory for all app data (config, cache, history, etc.)

# --- LiteLLM gateway ---
# All LLM calls (chat, vision, STT) route through a single LiteLLM gateway.
LITELLM_BASE_URL=http://10.10.10.10:4000/v1
LITELLM_API_KEY=                   # LiteLLM master key (optional if gateway has no auth)

# --- Model selection ---
# Default model for all requests (passed to LiteLLM as-is)
# SUMMARIZE_MODEL=mistral/mistral-large-latest
#
# Or pass per-request in the API body: {"model": "anthropic/claude-sonnet-4-6"}

# --- Transcription providers (for audio/video URLs) ---
# These call providers directly, NOT through LiteLLM.
MISTRAL_API_KEY=                   # Mistral Voxtral (tried first)
GROQ_API_KEY=                      # Groq Whisper (second in chain)
ASSEMBLYAI_API_KEY=                # AssemblyAI (third in chain)
FAL_KEY=                           # fal.ai (last in transcription chain)
# SUMMARIZE_TRANSCRIBER=auto       # auto, whisper, parakeet, canary

# --- Content extraction ---
# FIRECRAWL_API_KEY=               # Firecrawl for web content extraction
# APIFY_API_TOKEN=                 # Apify for web scraping

# --- yt-dlp ---
# YT_DLP_PATH=                     # Custom path to yt-dlp binary
# SUMMARIZE_YT_DLP_COOKIES_FROM_BROWSER=  # Cookie source (e.g. chrome, chrome:Profile 1)
