# =============================================================================
# Summarize_p2 API Server — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Server ---
SUMMARIZE_API_TOKEN=               # Required. Bearer token for API auth
SUMMARIZE_API_PORT=3000            # Optional. Default: 3000
# SUMMARIZE_DEFAULT_MODEL=          # Optional. Default model when request doesn't specify one

# --- LiteLLM proxy ---
# Route all LLM calls through a single gateway. Set each provider's base URL
# to your LiteLLM instance and use the same API key for all.
OPENAI_BASE_URL=https://litellm.p2lab.com/v1
ANTHROPIC_BASE_URL=https://litellm.p2lab.com/v1
GEMINI_BASE_URL=https://litellm.p2lab.com/v1
# XAI_BASE_URL=https://litellm.p2lab.com/v1
# NVIDIA_BASE_URL=https://litellm.p2lab.com/v1
# Z_AI_BASE_URL=https://litellm.p2lab.com/v1

# --- LLM API keys (use your LiteLLM key for all when proxying) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# XAI_API_KEY=
# NVIDIA_API_KEY=
# Z_AI_API_KEY=
# OPENROUTER_API_KEY=

# --- Model selection ---
# Default model for all requests (provider/model-id format)
# SUMMARIZE_MODEL=anthropic/claude-sonnet-4
#
# Or pass per-request in the API body: {"model": "anthropic/claude-sonnet-4"}
#
# For advanced model selection (auto rules, token bands, named presets),
# configure ~/.summarize/config.json — see docs for schema.

# --- Transcription providers (for audio/video URLs) ---
# These call providers directly, NOT through LiteLLM.
MISTRAL_API_KEY=                   # Mistral Voxtral (tried first)
GROQ_API_KEY=                      # Groq Whisper (second in chain)
ASSEMBLYAI_API_KEY=                # AssemblyAI (third in chain)
FAL_KEY=                           # fal.ai (last in transcription chain)
# OPENAI_WHISPER_BASE_URL=         # Override for OpenAI Whisper endpoint
# SUMMARIZE_TRANSCRIBER=auto       # auto, whisper, parakeet, canary

# --- Content extraction ---
# FIRECRAWL_API_KEY=               # Firecrawl for web content extraction
# APIFY_API_TOKEN=                 # Apify for web scraping

# --- yt-dlp ---
# YT_DLP_PATH=                     # Custom path to yt-dlp binary
# SUMMARIZE_YT_DLP_COOKIES_FROM_BROWSER=  # Cookie source (e.g. chrome, chrome:Profile 1)
